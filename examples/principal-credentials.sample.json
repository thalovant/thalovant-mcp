{
  "principals": {
    "oauth-sub-or-static-token-fingerprint": {
      "control": {
        "apiUrl": "https://api.thalovant.com",
        "accessToken": "thalovant-api-access-token"
      },
      "runtime": {
        "identity": {
          "access_key": "client-access-key",
          "password": "client-password",
          "site_id": "client-site-id",
          "default_master": "https://hub.example.com",
          "data_plane_endpoints": {
            "wss": "wss://hub.example.com/public",
            "https": "https://hub.example.com/public"
          }
        }
      },
      "allowedTools": ["thalovant_*"],
      "deniedTools": ["thalovant_delete_memory_item"]
    }
  }
}
