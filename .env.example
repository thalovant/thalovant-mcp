# Local stdio defaults.
THALOVANT_PROFILE=prod
THALOVANT_API_URL=https://api.thalovant.com

# Use one control-plane auth option for private/admin tools.
# THALOVANT_ACCESS_TOKEN=
# THALOVANT_EMAIL=
# THALOVANT_PASSWORD=

# Runtime identity options for local stdio usage.
# THALOVANT_ACCESS_KEY=
# THALOVANT_PASSWORD=
# THALOVANT_SITE_ID=
# THALOVANT_DEFAULT_MASTER=
# THALOVANT_HUB_WSS_HOST=
# THALOVANT_HUB_HTTPS_HOST=

# Streamable HTTP transport.
MCP_TRANSPORT=http
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=3000
MCP_PUBLIC_URL=http://127.0.0.1:3000
MCP_HTTP_ALLOWED_HOSTS=127.0.0.1:3000,localhost:3000
MCP_HTTP_ALLOWED_ORIGINS=
MCP_HTTP_AUTH_TOKEN=

# Production remote auth: prefer jwt or introspection over static tokens.
# MCP_HTTP_AUTH_MODE=jwt
# MCP_OAUTH_ISSUER=https://auth.example.com/
# MCP_OAUTH_JWKS_URL=https://auth.example.com/.well-known/jwks.json
# MCP_OAUTH_AUDIENCE=https://mcp.example.com/mcp
# MCP_OAUTH_AUTHORIZATION_SERVERS=https://auth.example.com/
# MCP_OAUTH_REQUIRED_SCOPES=mcp:thalovant

# MCP_HTTP_AUTH_MODE=introspection
# MCP_OAUTH_INTROSPECTION_URL=https://auth.example.com/oauth2/introspect
# MCP_OAUTH_CLIENT_ID=
# MCP_OAUTH_CLIENT_SECRET=

# Multi-user remote deployments should map each MCP principal to Thalovant credentials.
# THALOVANT_PRINCIPAL_CREDENTIALS_FILE=/run/secrets/thalovant-principals.json
# THALOVANT_PRINCIPAL_CREDENTIALS_DIR=/run/secrets/thalovant-principals
# THALOVANT_ALLOW_SHARED_CREDENTIALS=false

# Optional policy and audit controls.
# MCP_TOOL_ALLOWLIST=thalovant_*
# MCP_TOOL_DENYLIST=thalovant_delete_memory_item
# MCP_AUDIT_LOG=stderr
# MCP_AUDIT_LOG_FILE=/var/log/thalovant-mcp/audit.jsonl
